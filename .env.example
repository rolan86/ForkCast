# Required: Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override defaults
FORKCAST_DATA_DIR=./data
FORKCAST_DOMAINS_DIR=./domains
FORKCAST_DB_NAME=forkcast.db
FORKCAST_HOST=127.0.0.1
FORKCAST_PORT=5001
FORKCAST_LOG_LEVEL=info

# LLM Provider: "claude" (default) or "ollama"
# FORKCAST_LLM_PROVIDER=claude

# Ollama settings (only used when FORKCAST_LLM_PROVIDER=ollama)
# FORKCAST_OLLAMA_BASE_URL=http://localhost:11434/v1
# FORKCAST_OLLAMA_MODEL=llama3.1
